        {
          "name": "大批次執行（10個 API）",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"apiCalls\": [\n    {\"apiUrl\": \"https://httpbin.org/delay/1\", \"payload\": \"{\\\"id\\\": 1}\"},\n    {\"apiUrl\": \"https://httpbin.org/delay/1\", \"payload\": \"{\\\"id\\\": 2}\"},\n    {\"apiUrl\": \"https://httpbin.org/delay/1\", \"payload\": \"{\\\"id\\\": 3}\"},\n    {\"apiUrl\": \"https://httpbin.org/delay/1\", \"payload\": \"{\\\"id\\\": 4}\"},\n    {\"apiUrl\": \"https://httpbin.org/delay/1\", \"payload\": \"{\\\"id\\\": 5}\"},\n    {\"apiUrl\": \"https://httpbin.org/delay/1\", \"payload\": \"{\\\"id\\\": 6}\"},\n    {\"apiUrl\": \"https://httpbin.org/delay/1\", \"payload\": \"{\\\"id\\\": 7}\"},\n    {\"apiUrl\": \"https://httpbin.org/delay/1\", \"payload\": \"{\\\"id\\\": 8}\"},\n    {\"apiUrl\": \"https://httpbin.org/delay/1\", \"payload\": \"{\\\"id\\\": 9}\"},\n    {\"apiUrl\": \"https://httpbin.org/delay/1\", \"payload\": \"{\\\"id\\\": 10}\"}\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/process/parallelexecute",
              "host": ["{{base_url}}"],
              "path": ["api", "process", "parallelexecute"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has processInstanceId\", function () {",
