{
  "info": {
    "name": "Camunda Parallel Execute API",
    "description": "Camunda Multi-Instance 並行 API 執行測試集合",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "成功測試",
      "item": [
        {
          "name": "多 API 並行執行",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"apiCalls\": [\n    {\n      \"apiUrl\": \"https://httpbin.org/post\",\n      \"payload\": \"{\\\"test\\\": \\\"api1\\\"}\"\n    },\n    {\n      \"apiUrl\": \"https://httpbin.org/post\",\n      \"payload\": \"{\\\"test\\\": \\\"api2\\\"}\"\n    },\n    {\n      \"apiUrl\": \"https://httpbin.org/post\",\n      \"payload\": \"{\\\"test\\\": \\\"api3\\\"}\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/process/parallelexecute",
              "host": ["{{base_url}}"],
              "path": ["api", "process", "parallelexecute"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has processInstanceId\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('processInstanceId');",
                  "});",
                  "",
                  "pm.test(\"Overall status is SUCCESS\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.overallStatus).to.eql('SUCCESS');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
