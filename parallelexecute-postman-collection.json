                  "    pm.expect(jsonData).to.have.property('processInstanceId');",
                  "});",
                  "",
                  "pm.test(\"Total count is 10\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.totalCount).to.eql(10);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
