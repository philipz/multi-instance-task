    {
      "name": "效能測試",
      "item": [
        {
          "name": "執行時間測試",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"apiCalls\": [\n    {\"apiUrl\": \"https://httpbin.org/delay/2\", \"payload\": \"{\\\"test\\\": \\\"performance1\\\"}\"},\n    {\"apiUrl\": \"https://httpbin.org/delay/2\", \"payload\": \"{\\\"test\\\": \\\"performance2\\\"}\"}\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/process/parallelexecute",
              "host": ["{{base_url}}"],
              "path": ["api", "process", "parallelexecute"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response time is reasonable\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(10000);",
                  "});",
                  "",
                  "pm.test(\"Parallel execution efficiency\", function () {",
                  "    // 兩個 2 秒的 API 並行執行應該小於 6 秒（允許一些開銷）",
                  "    pm.expect(pm.response.responseTime).to.be.below(6000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
